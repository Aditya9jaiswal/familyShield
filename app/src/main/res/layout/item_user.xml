<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardUser"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ========== HEADER: NAME + STATUS ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_status"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- ========== CONTACT INFO ========== -->
        <TextView
            android:id="@+id/tvMobile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#64748B"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#64748B"
            android:layout_marginBottom="4dp" />

        <!-- SIM Operator -->
        <TextView
            android:id="@+id/tvSimOperator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666"
            android:layout_marginTop="2dp" />

        <!-- SIM Country -->
        <TextView
            android:id="@+id/tvSimCountry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666"
            android:layout_marginTop="2dp" />

        <!-- Network Type -->
        <TextView
            android:id="@+id/tvNetworkType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666"
            android:layout_marginTop="2dp" />

        <!-- ========== ADDRESS ========== -->
        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#64748B"
            android:layout_marginBottom="12dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- ========== LOCATION CARD ========== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#F8FAFC"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvLatitude"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="#475569"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvLongitude"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="#475569"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvLastUpdated"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:textColor="#94A3B8" />

                    <TextView
                        android:id="@+id/tvBatteryLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#94A3B8" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========== DEVICE OWNER STATUS ========== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDeviceOwner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#E8F5E9"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📱 Device Owner Mode"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32" />

                <TextView
                    android:id="@+id/tvDeviceOwnerStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ ACTIVE"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:background="#4CAF50"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========== IMEI NUMBER ========== -->
        <TextView
            android:id="@+id/tvImei"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- ========== APP LOCK SECTION (Grid Layout) ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔒 App Lock"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FF5722"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Grid Layout for App Lock Buttons -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:padding="4dp"
            android:layout_marginBottom="8dp">

            <!-- Full Blank Lock Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFullBlankLock"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="⬛ Full Blank"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:backgroundTint="#F44336"
                android:textColor="#FFFFFF" />

            <!-- Lost Phone Lock Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLostMessageLock"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="📱 Lost Phone"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:backgroundTint="#FF9800"
                android:textColor="#FFFFFF" />

            <!-- Unlock App Button (Full Width in Row 2) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUnlockApp"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_columnWeight="1"
                android:layout_columnSpan="2"
                android:layout_margin="4dp"
                android:text="🔓 Unlock App"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF" />

        </GridLayout>

        <!-- ========== FACTORY RESET CONTROL BUTTON ========== -->
        <Button
            android:id="@+id/btnFactoryResetControl"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="⚙️ Factory Reset: ENABLED"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <!-- ========== BUTTONS ROW 1 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLock"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="🔒 Lock"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:backgroundTint="#3B82F6"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLocate"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="📍 Locate"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:backgroundTint="#10B981"
                android:textColor="#FFFFFF"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSiren"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="🔊 Siren"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:backgroundTint="#F59E0B"
                android:textColor="#FFFFFF"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- ========== BUTTONS ROW 2 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewMap"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="🗺️ Map"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:backgroundTint="#8B5CF6"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCall"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="📞 Call"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:backgroundTint="#EC4899"
                android:textColor="#FFFFFF"
                android:layout_marginHorizontal="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewDetails"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="👤 Details"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="8dp"
                app:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- ========== FACTORY RESET BUTTON ========== -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFactoryReset"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="⚠️ FACTORY RESET"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:backgroundTint="#EF4444"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <!-- ========== LOST COMPLAINT BUTTON ========== -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLostComplaint"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="📄 FILE COMPLAINT"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>